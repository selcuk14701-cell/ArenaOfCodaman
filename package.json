<!DOCTYPE html>
<html lang="tr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<title>KODAMAN // Taktik Arena</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@600;800&family=Rajdhani:wght@500;600;700&family=Share+Tech+Mono&display=swap" rel="stylesheet">
<style>
:root{
  --bg:#0a0d10;
  --bg2:#0d1216;
  --panel:rgba(16,22,26,0.88);
  --panel-light:rgba(24,32,38,0.92);
  --line:rgba(76,201,240,0.18);
  --amber:#ff9f1c;
  --cyan:#4cc9f0;
  --red:#e63946;
  --green:#3ddc97;
  --text:#d9e4e8;
  --text-dim:#7c8a92;
  --font-display:'Orbitron',sans-serif;
  --font-body:'Rajdhani',sans-serif;
  --font-mono:'Share Tech Mono',monospace;
}
*{box-sizing:border-box; margin:0; padding:0;}
html,body{width:100%;height:100%; overflow:hidden; background:var(--bg); font-family:var(--font-body); color:var(--text); -webkit-user-select:none; user-select:none;}
#app{position:fixed; inset:0; width:100%; height:100%;}

/* ---------- shared background hex/grid texture ---------- */
.hexbg{
  position:fixed; inset:0; z-index:0; pointer-events:none;
  background:
    radial-gradient(ellipse at 20% 10%, rgba(76,201,240,0.07), transparent 55%),
    radial-gradient(ellipse at 85% 85%, rgba(255,159,28,0.06), transparent 50%),
    repeating-linear-gradient(0deg, rgba(255,255,255,0.015) 0px, rgba(255,255,255,0.015) 1px, transparent 1px, transparent 34px),
    repeating-linear-gradient(90deg, rgba(255,255,255,0.015) 0px, rgba(255,255,255,0.015) 1px, transparent 1px, transparent 34px),
    linear-gradient(160deg,#0a0d10,#0d1319 60%,#0a0d10);
}
.radar-sweep{
  position:fixed; top:50%; left:50%; width:1400px; height:1400px; margin:-700px 0 0 -700px;
  border-radius:50%; z-index:0; pointer-events:none; opacity:0.35;
  background:conic-gradient(from 0deg, rgba(76,201,240,0.16), transparent 25%);
  animation:spin 9s linear infinite;
}
@keyframes spin{ to{ transform:rotate(360deg); } }

.screen{ position:fixed; inset:0; z-index:1; display:none; align-items:center; justify-content:center; flex-direction:column; }
.screen.active{ display:flex; }

.brand{
  font-family:var(--font-display); font-weight:800; letter-spacing:6px;
  font-size:2.4rem; color:var(--cyan); text-shadow:0 0 22px rgba(76,201,240,0.55);
  margin-bottom:6px;
}
.brand small{ display:block; font-family:var(--font-body); letter-spacing:4px; font-size:0.75rem; color:var(--amber); font-weight:700; margin-top:4px;}

.panel{
  background:var(--panel); border:1px solid var(--line); border-radius:6px;
  box-shadow:0 0 0 1px rgba(0,0,0,0.4), 0 20px 60px rgba(0,0,0,0.55);
  backdrop-filter:blur(6px);
  padding:34px 40px;
  position:relative;
}
.panel::before{
  content:''; position:absolute; top:-1px; left:18px; right:18px; height:2px;
  background:linear-gradient(90deg, transparent, var(--cyan), transparent);
}
.corner-tag{
  position:absolute; top:0; left:0; font-family:var(--font-mono); font-size:0.65rem; color:var(--text-dim);
  padding:4px 8px; letter-spacing:2px;
}

label.field-label{ display:block; font-size:0.72rem; letter-spacing:2px; color:var(--text-dim); margin-bottom:6px; text-transform:uppercase; font-weight:700;}
input[type=text]{
  width:100%; background:#050708; border:1px solid var(--line); color:var(--text);
  font-family:var(--font-mono); font-size:1rem; padding:12px 14px; border-radius:3px; outline:none;
  letter-spacing:1px;
}
input[type=text]:focus{ border-color:var(--cyan); box-shadow:0 0 0 2px rgba(76,201,240,0.15);}

.btn{
  font-family:var(--font-body); font-weight:700; letter-spacing:1.5px; text-transform:uppercase;
  font-size:0.85rem; padding:13px 22px; border-radius:3px; border:1px solid var(--line);
  background:linear-gradient(180deg, rgba(76,201,240,0.14), rgba(76,201,240,0.03));
  color:var(--cyan); cursor:pointer; transition:all .15s ease; position:relative;
}
.btn:hover{ background:rgba(76,201,240,0.22); box-shadow:0 0 18px rgba(76,201,240,0.25); transform:translateY(-1px);}
.btn:active{ transform:translateY(0px); }
.btn.primary{ background:linear-gradient(180deg, rgba(255,159,28,0.22), rgba(255,159,28,0.05)); color:var(--amber); border-color:rgba(255,159,28,0.35);}
.btn.primary:hover{ background:rgba(255,159,28,0.3); box-shadow:0 0 18px rgba(255,159,28,0.3);}
.btn.danger{ color:var(--red); border-color:rgba(230,57,70,0.4);}
.btn.danger:hover{ background:rgba(230,57,70,0.18); box-shadow:0 0 18px rgba(230,57,70,0.25);}
.btn.small{ padding:8px 12px; font-size:0.7rem;}
.btn:disabled{ opacity:0.35; cursor:not-allowed; transform:none; box-shadow:none;}

.err-msg{ color:var(--red); font-family:var(--font-mono); font-size:0.8rem; margin-top:10px; min-height:18px; letter-spacing:0.5px;}
.hint{ color:var(--text-dim); font-size:0.75rem; margin-top:14px; letter-spacing:0.5px; line-height:1.5;}

/* ---------------- NICKNAME SCREEN ---------------- */
#screen-nickname .panel{ width:420px; max-width:90vw; text-align:center;}
#screen-nickname .brand{ margin-bottom:22px;}
#nick-input{ text-align:center; font-size:1.15rem;}

/* ---------------- MAIN MENU ---------------- */
#screen-menu{ padding:20px;}
.menu-wrap{ width:100%; max-width:980px; display:flex; flex-direction:column; gap:18px; z-index:1;}
.menu-top{ display:flex; justify-content:space-between; align-items:center; flex-wrap:wrap; gap:14px;}
.profile-card{
  display:flex; align-items:center; gap:16px; padding:14px 22px;
}
.avatar{
  width:52px; height:52px; border-radius:50%; display:flex; align-items:center; justify-content:center;
  background:radial-gradient(circle at 30% 30%, rgba(76,201,240,0.5), rgba(76,201,240,0.08));
  border:1px solid var(--cyan); font-family:var(--font-display); font-weight:800; color:var(--cyan); font-size:1.2rem;
}
.profile-name{ font-family:var(--font-display); font-weight:700; font-size:1.15rem; color:var(--text); letter-spacing:1px;}
.profile-prestige{ font-family:var(--font-mono); font-size:0.85rem; color:var(--amber); margin-top:2px;}

.menu-grid{ display:grid; grid-template-columns:repeat(auto-fit,minmax(220px,1fr)); gap:16px;}
.menu-card{
  padding:24px 20px; cursor:pointer; transition:all .18s ease;
}
.menu-card:hover{ border-color:var(--cyan); box-shadow:0 0 24px rgba(76,201,240,0.18); transform:translateY(-3px);}
.menu-card h3{ font-family:var(--font-display); font-size:1rem; color:var(--cyan); letter-spacing:1.5px; margin-bottom:8px;}
.menu-card p{ font-size:0.85rem; color:var(--text-dim); line-height:1.4;}
.menu-card .tag{ position:absolute; top:10px; right:12px; font-family:var(--font-mono); font-size:0.65rem; color:var(--text-dim);}

/* ---------------- MODALS ---------------- */
.modal-overlay{
  position:fixed; inset:0; background:rgba(4,6,8,0.72); z-index:20; display:none;
  align-items:center; justify-content:center; backdrop-filter:blur(3px);
}
.modal-overlay.active{ display:flex;}
.modal{ width:520px; max-width:92vw; max-height:82vh; overflow-y:auto; }
.modal h2{ font-family:var(--font-display); font-size:1.1rem; color:var(--amber); letter-spacing:2px; margin-bottom:18px; display:flex; justify-content:space-between; align-items:center;}
.modal .close-x{ cursor:pointer; color:var(--text-dim); font-size:1.2rem; line-height:1;}
.modal .close-x:hover{ color:var(--red);}
.row-flex{ display:flex; gap:10px; }
.row-flex input{ flex:1; }

.list-item{
  display:flex; justify-content:space-between; align-items:center; padding:10px 12px;
  border:1px solid var(--line); border-radius:3px; margin-top:8px; background:rgba(255,255,255,0.02);
}
.status-dot{ width:8px; height:8px; border-radius:50%; display:inline-block; margin-right:8px;}
.status-dot.online{ background:var(--green); box-shadow:0 0 6px var(--green);}
.status-dot.offline{ background:#555;}
.lb-rank{ font-family:var(--font-mono); color:var(--text-dim); width:28px; display:inline-block;}
.lb-rank.gold{ color:#ffd700;}
.lb-rank.silver{ color:#d0d8dc;}
.lb-rank.bronze{ color:#cd7f32;}

.private-tabs{ display:flex; gap:8px; margin-bottom:18px;}
.private-tabs .btn{ flex:1;}
.private-tabs .btn.active-tab{ background:rgba(76,201,240,0.25);}
.private-pane{ display:none;}
.private-pane.active{ display:block;}
.code-display{
  font-family:var(--font-mono); font-size:1.8rem; letter-spacing:8px; text-align:center;
  color:var(--green); padding:16px; border:1px dashed var(--green); border-radius:4px; margin:14px 0;
  background:rgba(61,220,151,0.06);
}

/* ---------------- GAME SCREEN ---------------- */
#screen-game{ padding:0; display:none;}
#screen-game.active{ display:block;}
#gameCanvas{ position:fixed; inset:0; width:100%; height:100%; background:#12181c; z-index:1;}

.hud{ position:fixed; inset:0; z-index:5; pointer-events:none; font-family:var(--font-body);}
.hud > *{ pointer-events:auto; }

#timerBadge{
  position:absolute; top:16px; left:50%; transform:translateX(-50%);
  background:var(--panel); border:1px solid var(--line); border-radius:4px;
  padding:8px 22px; font-family:var(--font-mono); font-size:1.4rem; color:var(--amber);
  letter-spacing:2px; text-align:center; min-width:120px;
}
#timerBadge .room-type{ display:block; font-family:var(--font-body); font-size:0.6rem; color:var(--text-dim); letter-spacing:1.5px; margin-top:2px; text-transform:uppercase;}

#killfeed{
  position:absolute; top:16px; right:16px; width:260px; display:flex; flex-direction:column; gap:6px; align-items:flex-end;
}
.killfeed-item{
  background:rgba(10,13,16,0.75); border-left:2px solid var(--red); padding:6px 10px; font-size:0.78rem;
  border-radius:2px; color:var(--text); animation:fadeInFeed .25s ease; white-space:nowrap;
}
@keyframes fadeInFeed{ from{opacity:0; transform:translateX(20px);} to{opacity:1; transform:translateX(0);} }

#scoreboardPanel{
  position:absolute; top:70px; left:14px; width:220px;
  background:var(--panel); border:1px solid var(--line); border-radius:4px; padding:10px 12px;
  display:none;
}
#scoreboardPanel.show{ display:block; }
#scoreboardPanel h4{ font-family:var(--font-display); font-size:0.72rem; color:var(--cyan); letter-spacing:1.5px; margin-bottom:8px;}
.sb-row{ display:flex; justify-content:space-between; font-size:0.78rem; padding:3px 0; border-bottom:1px solid rgba(255,255,255,0.05);}
.sb-row.me{ color:var(--amber); font-weight:700;}
.sb-name{ overflow:hidden; text-overflow:ellipsis; white-space:nowrap; max-width:120px;}

#tabScoreboard{
  position:absolute; top:90px; left:50%; transform:translateX(-50%); width:380px;
  background:var(--panel); border:1px solid var(--line); border-radius:6px; padding:16px 20px; display:none;
}
#tabScoreboard.show{ display:block;}
#tabScoreboard h4{ font-family:var(--font-display); font-size:0.85rem; color:var(--amber); letter-spacing:2px; margin-bottom:10px; text-align:center;}
#tabScoreboard .sb-row{ font-size:0.9rem; padding:6px 0;}

#healthBar{
  position:absolute; bottom:18px; left:18px; width:220px;
}
#healthBar .lbl{ font-size:0.7rem; color:var(--text-dim); letter-spacing:1.5px; margin-bottom:4px; text-transform:uppercase;}
#healthBarTrack{ width:100%; height:14px; background:#1a1f22; border:1px solid var(--line); border-radius:3px; overflow:hidden;}
#healthBarFill{ height:100%; background:linear-gradient(90deg, var(--red), var(--green)); width:100%; transition:width .15s ease;}

#weaponHud{
  position:absolute; bottom:18px; right:18px; display:flex; gap:8px;
}
.weapon-slot{
  width:64px; height:64px; border:1px solid var(--line); border-radius:4px; background:var(--panel);
  display:flex; flex-direction:column; align-items:center; justify-content:center; cursor:pointer; position:relative;
}
.weapon-slot.active{ border-color:var(--amber); box-shadow:0 0 14px rgba(255,159,28,0.35);}
.weapon-slot .icon{ font-size:1.4rem;}
.weapon-slot .num{ position:absolute; top:2px; left:4px; font-family:var(--font-mono); font-size:0.6rem; color:var(--text-dim);}

#killfeedCenter{
  position:absolute; top:50%; left:50%; transform:translate(-50%,-50%); text-align:center; display:none;
}
#deathBanner{
  position:absolute; top:40%; left:50%; transform:translate(-50%,-50%); text-align:center; display:none;
  font-family:var(--font-display); color:var(--red); font-size:1.6rem; letter-spacing:3px; text-shadow:0 0 20px rgba(230,57,70,0.6);
}

.pc-hint{
  position:absolute; bottom:18px; left:50%; transform:translateX(-50%);
  font-family:var(--font-mono); font-size:0.7rem; color:var(--text-dim); background:rgba(0,0,0,0.4); padding:6px 14px; border-radius:3px;
}

/* -------- mobile controls -------- */
.mobile-only{ display:none; }
.joystick-zone{
  position:absolute; width:140px; height:140px; border-radius:50%;
  background:rgba(255,255,255,0.04); border:1px solid var(--line);
}
#joyLeft{ bottom:26px; left:26px;}
#joyRight{ bottom:26px; right:126px;}
.joystick-knob{
  position:absolute; width:56px; height:56px; border-radius:50%; background:rgba(76,201,240,0.28);
  border:1px solid var(--cyan); top:50%; left:50%; transform:translate(-50%,-50%); pointer-events:none;
}
#fireBtn{
  position:absolute; bottom:96px; right:26px; width:84px; height:84px; border-radius:50%;
  background:radial-gradient(circle, rgba(230,57,70,0.35), rgba(230,57,70,0.08));
  border:2px solid var(--red); color:var(--red); font-family:var(--font-display); font-weight:700; font-size:0.75rem;
  display:flex; align-items:center; justify-content:center; letter-spacing:1px;
}
#fireBtn.pressed{ background:rgba(230,57,70,0.5);}
#mobileWeaponRow{
  position:absolute; bottom:18px; left:50%; transform:translateX(-50%); display:flex; gap:8px;
}

/* ---------------- RESULTS ---------------- */
#screen-results .panel{ width:520px; max-width:92vw;}
#screen-results h2{ font-family:var(--font-display); color:var(--amber); letter-spacing:2px; text-align:center; margin-bottom:6px; font-size:1.3rem;}
#screen-results .sub{ text-align:center; color:var(--text-dim); font-size:0.85rem; margin-bottom:20px;}
.result-row{ display:flex; justify-content:space-between; align-items:center; padding:10px 14px; border-radius:3px; margin-bottom:6px; background:rgba(255,255,255,0.03); font-family:var(--font-mono);}
.result-row.me{ border:1px solid var(--amber); background:rgba(255,159,28,0.08);}
.prestige-note{
  margin-top:18px; padding:12px 14px; border-radius:4px; font-size:0.85rem; text-align:center; line-height:1.5;
}
.prestige-note.awarded{ background:rgba(61,220,151,0.1); border:1px solid rgba(61,220,151,0.35); color:var(--green);}
.prestige-note.none{ background:rgba(230,57,70,0.1); border:1px solid rgba(230,57,70,0.35); color:var(--red);}

@media (max-width: 820px){
  .mobile-only{ display:block; }
  .pc-only{ display:none !important; }
  #scoreboardPanel{ display:block; top:64px; }
  .menu-grid{ grid-template-columns:1fr;}
}
</style>
</head>
<body>
<div class="hexbg"></div>
<div class="radar-sweep"></div>
<div id="app">

  <!-- ============ NICKNAME SCREEN ============ -->
  <div class="screen active" id="screen-nickname">
    <div class="panel">
      <span class="corner-tag">// KİMLİK DOĞRULAMA</span>
      <div class="brand">KODAMAN<small>Taktik Arena — Kod Adı Seç</small></div>
      <label class="field-label">Benzersiz Kullanıcı Adı</label>
      <input type="text" id="nick-input" maxlength="16" placeholder="ör: GolgeAvcisi" autocomplete="off">
      <div class="err-msg" id="nick-error"></div>
      <button class="btn primary" style="width:100%; margin-top:6px;" id="nick-submit">Arenaya Katıl</button>
      <div class="hint">İsimler benzersizdir — bu tarayıcıda daha önce alınmış bir isim tekrar kullanılamaz. 3-16 karakter, harf/rakam/alt çizgi.</div>
    </div>
  </div>

  <!-- ============ MAIN MENU ============ -->
  <div class="screen" id="screen-menu">
    <div class="menu-wrap">
      <div class="menu-top">
        <div class="panel profile-card">
          <div class="avatar" id="menu-avatar">?</div>
          <div>
            <div class="profile-name" id="menu-nick">—</div>
            <div class="profile-prestige">PRESTİJ: <span id="menu-prestige">0</span></div>
          </div>
        </div>
        <div style="display:flex; gap:10px;">
          <button class="btn small" id="btn-open-friends">👥 Arkadaşlar</button>
          <button class="btn small" id="btn-open-leaderboard">🏆 Liderlik</button>
        </div>
      </div>

      <div class="menu-grid">
        <div class="panel menu-card" id="card-random">
          <span class="tag">GENEL</span>
          <h3>⚡ Rastgele Katıl</h3>
          <p>Herkese açık genel odada rastgele oyunculara/rakiplere karşı savaş. Kazananlar prestij puanı kazanır.</p>
        </div>
        <div class="panel menu-card" id="card-private">
          <span class="tag">ÖZEL</span>
          <h3>🔒 Özel Oda</h3>
          <p>Kod ile oda kur veya arkadaşının kodunu girerek katıl. Hile/kasmayı önlemek için prestij verilmez.</p>
        </div>
        <div class="panel menu-card" id="card-friends2">
          <span class="tag">SOSYAL</span>
          <h3>👥 Arkadaş Ekle</h3>
          <p>Diğer kod adlarını arayarak arkadaş listene ekle, çevrimiçi durumlarını takip et.</p>
        </div>
        <div class="panel menu-card" id="card-leaderboard2">
          <span class="tag">SIRALAMA</span>
          <h3>🌍 Dünya Liderlik Tablosu</h3>
          <p>En yüksek prestije sahip benzersiz kod adlarını gör.</p>
        </div>
      </div>
      <div class="hint" style="text-align:center;">Silahlar: 🎯 Keskin Nişancı · 🔫 AK47 · 🔪 Bıçak &nbsp;|&nbsp; PC: TAB basılı tutarak skor tablosu · Mobil: sol panelde her zaman görünür</div>
    </div>
  </div>

  <!-- ============ FRIENDS MODAL ============ -->
  <div class="modal-overlay" id="modal-friends">
    <div class="panel modal">
      <h2>Arkadaş Paneli <span class="close-x" data-close="modal-friends">✕</span></h2>
      <label class="field-label">Kod adı ile ara ve ekle</label>
      <div class="row-flex">
        <input type="text" id="friend-search" placeholder="Kullanıcı adı yaz...">
        <button class="btn small" id="friend-add-btn">Ekle</button>
      </div>
      <div class="err-msg" id="friend-error"></div>
      <div style="margin-top:18px;">
        <label class="field-label">Arkadaş Listesi</label>
        <div id="friend-list"></div>
      </div>
    </div>
  </div>

  <!-- ============ LEADERBOARD MODAL ============ -->
  <div class="modal-overlay" id="modal-leaderboard">
    <div class="panel modal">
      <h2>🌍 Dünya Prestij Liderlik Tablosu <span class="close-x" data-close="modal-leaderboard">✕</span></h2>
      <div id="leaderboard-list"></div>
    </div>
  </div>

  <!-- ============ PRIVATE ROOM MODAL ============ -->
  <div class="modal-overlay" id="modal-private">
    <div class="panel modal">
      <h2>🔒 Özel Oda <span class="close-x" data-close="modal-private">✕</span></h2>
      <div class="private-tabs">
        <button class="btn active-tab" id="tab-create" data-tab="create">Oda Kur</button>
        <button class="btn" id="tab-join" data-tab="join">Kod ile Katıl</button>
      </div>
      <div class="private-pane active" id="pane-create">
        <p style="font-size:0.85rem; color:var(--text-dim); line-height:1.5;">Oda kurulunca doğrudan içine girersin, kodu arkadaşınla paylaş. Bu oda türünde maç sonunda prestij puanı verilmez.</p>
        <button class="btn primary" style="width:100%; margin-top:14px;" id="btn-generate-code">Oda Kur ve Başlat</button>
        <div class="err-msg" id="create-error"></div>
      </div>
      <div class="private-pane" id="pane-join">
        <label class="field-label">Davet Kodu</label>
        <input type="text" id="join-code-input" maxlength="6" placeholder="ör: A1B2C3" style="text-transform:uppercase;">
        <div class="err-msg" id="join-error"></div>
        <button class="btn primary" style="width:100%; margin-top:14px;" id="btn-join-code">Odaya Katıl</button>
      </div>
    </div>
  </div>

  <!-- ============ GAME SCREEN ============ -->
  <div class="screen" id="screen-game">
    <canvas id="gameCanvas"></canvas>
    <div class="hud">
      <div id="timerBadge">05:00<span class="room-type" id="roomTypeLabel">GENEL ODA</span></div>
      <div id="killfeed"></div>
      <div id="scoreboardPanel">
        <h4>SKOR TABLOSU</h4>
        <div id="scoreboardRows"></div>
      </div>
      <div id="tabScoreboard">
        <h4>ANLIK SKOR TABLOSU (TAB)</h4>
        <div id="tabScoreboardRows"></div>
      </div>
      <div id="healthBar">
        <div class="lbl">CAN</div>
        <div id="healthBarTrack"><div id="healthBarFill"></div></div>
      </div>
      <div id="weaponHud">
        <div class="weapon-slot" data-w="0"><span class="num">1</span><span class="icon">🎯</span></div>
        <div class="weapon-slot" data-w="1"><span class="num">2</span><span class="icon">🔫</span></div>
        <div class="weapon-slot" data-w="2"><span class="num">3</span><span class="icon">🔪</span></div>
      </div>
      <div id="deathBanner">ELİMİNE EDİLDİN</div>
      <div class="pc-hint pc-only">WASD Hareket · Fare Nişan Al · Sol Tık Ateş · 1/2/3 Silah · TAB Skor Tablosu</div>

      <!-- mobile controls -->
      <div class="mobile-only" id="joyLeft" style="position:absolute;"><div class="joystick-knob" id="joyLeftKnob"></div></div>
      <div class="mobile-only" id="joyRight" style="position:absolute;"><div class="joystick-knob" id="joyRightKnob"></div></div>
      <div class="mobile-only" id="fireBtn">ATEŞ</div>
      <div class="mobile-only" id="mobileWeaponRow">
        <div class="weapon-slot" data-mw="0" style="width:52px;height:52px;"><span class="icon">🎯</span></div>
        <div class="weapon-slot" data-mw="1" style="width:52px;height:52px;"><span class="icon">🔫</span></div>
        <div class="weapon-slot" data-mw="2" style="width:52px;height:52px;"><span class="icon">🔪</span></div>
      </div>
    </div>
  </div>

  <!-- ============ RESULTS SCREEN ============ -->
  <div class="screen" id="screen-results">
    <div class="panel">
      <h2>MAÇ SONUCU</h2>
      <div class="sub" id="results-sub">Süre doldu — nihai sıralama</div>
      <div id="results-list"></div>
      <div class="prestige-note" id="prestige-note"></div>
      <button class="btn primary" style="width:100%; margin-top:20px;" id="btn-back-menu">Ana Menüye Dön</button>
    </div>
  </div>

</div>

<script>

'use strict';
/* =========================================================================
   KODAMAN ARENA — GERÇEK ZAMANLI MULTİPLAYER İSTEMCİSİ (WebSocket)
   ========================================================================= */

/* ---------------- WEBSOCKET BAĞLANTISI ---------------- */
const WS_URL = (location.protocol === 'https:' ? 'wss://' : 'ws://') + location.host;
let socket = null;
let currentNick = null;
let wsReady = false;

function connectSocket(onOpenCb){
  if(socket && socket.readyState === WebSocket.OPEN){ if(onOpenCb) onOpenCb(); return; }
  socket = new WebSocket(WS_URL);
  socket.addEventListener('open', ()=>{ wsReady = true; if(onOpenCb) onOpenCb(); });
  socket.addEventListener('close', ()=>{ wsReady = false; handleDisconnect(); });
  socket.addEventListener('error', ()=>{ /* close event de tetiklenecek */ });
  socket.addEventListener('message', (ev)=>{
    let msg; try{ msg = JSON.parse(ev.data); }catch(e){ return; }
    handleServerMessage(msg);
  });
}
function sendMsg(obj){
  if(socket && socket.readyState === WebSocket.OPEN) socket.send(JSON.stringify(obj));
}
function handleDisconnect(){
  if(document.getElementById('screen-game').classList.contains('active')){
    alert('Sunucu bağlantısı koptu. Ana menüye dönülüyor.');
    G = null;
    enterMenu();
  }
}

/* =========================================================================
   SCREEN NAVIGATION
   ========================================================================= */
function showScreen(id){
  document.querySelectorAll('.screen').forEach(s=>s.classList.remove('active'));
  document.getElementById(id).classList.add('active');
}
function openModal(id){ document.getElementById(id).classList.add('active'); }
function closeModal(id){ document.getElementById(id).classList.remove('active'); }
document.querySelectorAll('[data-close]').forEach(el=>{
  el.addEventListener('click', ()=> closeModal(el.getAttribute('data-close')));
});
document.querySelectorAll('.modal-overlay').forEach(ov=>{
  ov.addEventListener('click', (e)=>{ if(e.target === ov) ov.classList.remove('active'); });
});
function escapeHtml(s){ const d=document.createElement('div'); d.textContent=s; return d.innerHTML; }

/* =========================================================================
   NICKNAME / KAYIT
   ========================================================================= */
const nickInput = document.getElementById('nick-input');
const nickError = document.getElementById('nick-error');
const nickSubmitBtn = document.getElementById('nick-submit');
nickSubmitBtn.addEventListener('click', submitNick);
nickInput.addEventListener('keydown', e=>{ if(e.key === 'Enter') submitNick(); });

function submitNick(){
  const raw = nickInput.value.trim();
  nickError.textContent = '';
  if(raw.length < 3 || raw.length > 16){ nickError.textContent = 'İsim 3-16 karakter arasında olmalı.'; return; }
  if(!/^[A-Za-z0-9_ığüşöçİĞÜŞÖÇ]+$/.test(raw)){ nickError.textContent = 'Sadece harf, rakam ve alt çizgi kullanabilirsin.'; return; }
  nickSubmitBtn.disabled = true;
  nickError.textContent = 'Sunucuya bağlanılıyor...';
  connectSocket(()=>{ sendMsg({ type:'register', nickname: raw }); });
}

let currentPrestige = 0;
function handleServerMessage(msg){
  switch(msg.type){
    case 'register_ok':
      currentNick = msg.nickname; currentPrestige = msg.prestige;
      nickSubmitBtn.disabled = false;
      enterMenu();
      break;
    case 'register_fail':
      nickSubmitBtn.disabled = false;
      nickError.textContent = '⚠ ' + msg.reason;
      break;
    case 'friend_add_fail':
      document.getElementById('friend-error').textContent = msg.reason;
      break;
    case 'friend_list':
      renderFriendList(msg.friends);
      break;
    case 'leaderboard':
      renderLeaderboardList(msg.list);
      break;
    case 'room_joined':
      onRoomJoined(msg);
      break;
    case 'error':
      alert(msg.message);
      break;
    case 'player_joined':
      onPlayerJoined(msg.player);
      break;
    case 'player_left':
      onPlayerLeft(msg.id);
      break;
    case 'state_update':
      onStateUpdate(msg);
      break;
    case 'bullet':
      onBulletVisual(msg);
      break;
    case 'hit':
      onHit(msg);
      break;
    case 'kill':
      onKill(msg);
      break;
    case 'respawn':
      onRespawn(msg);
      break;
    case 'timer':
      onTimer(msg.timeLeft);
      break;
    case 'match_end':
      onMatchEnd(msg);
      break;
  }
}

function enterMenu(){
  document.getElementById('menu-nick').textContent = currentNick;
  document.getElementById('menu-avatar').textContent = currentNick.charAt(0).toUpperCase();
  document.getElementById('menu-prestige').textContent = currentPrestige;
  showScreen('screen-menu');
}

/* =========================================================================
   ARKADAŞLAR
   ========================================================================= */
document.getElementById('btn-open-friends').addEventListener('click', ()=>{ sendMsg({type:'friend_list_request'}); openModal('modal-friends'); });
document.getElementById('card-friends2').addEventListener('click', ()=>{ sendMsg({type:'friend_list_request'}); openModal('modal-friends'); });
document.getElementById('friend-add-btn').addEventListener('click', addFriend);
document.getElementById('friend-search').addEventListener('keydown', e=>{ if(e.key==='Enter') addFriend(); });

function addFriend(){
  const input = document.getElementById('friend-search');
  const errEl = document.getElementById('friend-error');
  const name = input.value.trim();
  errEl.textContent = '';
  if(!name) return;
  sendMsg({ type:'friend_add', target:name });
  input.value = '';
}
function renderFriendList(friends){
  const list = document.getElementById('friend-list');
  if(!friends || friends.length === 0){
    list.innerHTML = '<div class="hint">Henüz arkadaşın yok. Yukarıdan bir kod adı ara.</div>';
    return;
  }
  list.innerHTML = friends.map(f=>{
    return `<div class="list-item">
      <span><span class="status-dot ${f.online?'online':'offline'}"></span>${escapeHtml(f.name)}</span>
      <span style="font-family:var(--font-mono); font-size:0.7rem; color:var(--text-dim);">PRESTİJ ${f.prestige}</span>
    </div>`;
  }).join('');
}

/* =========================================================================
   LİDERLİK TABLOSU
   ========================================================================= */
document.getElementById('btn-open-leaderboard').addEventListener('click', ()=>{ sendMsg({type:'leaderboard_request'}); openModal('modal-leaderboard'); });
document.getElementById('card-leaderboard2').addEventListener('click', ()=>{ sendMsg({type:'leaderboard_request'}); openModal('modal-leaderboard'); });

function renderLeaderboardList(data){
  const el = document.getElementById('leaderboard-list');
  if(!data || data.length===0){ el.innerHTML = '<div class="hint">Henüz kayıtlı prestij yok.</div>'; return; }
  el.innerHTML = data.map((d,i)=>{
    let rankClass = '';
    if(i===0) rankClass='gold'; else if(i===1) rankClass='silver'; else if(i===2) rankClass='bronze';
    const me = d.name.toLowerCase() === currentNick.toLowerCase();
    return `<div class="list-item" style="${me?'border-color:var(--amber);':''}">
      <span><span class="lb-rank ${rankClass}">#${i+1}</span>${escapeHtml(d.name)}${me?' <span style="color:var(--amber); font-size:0.7rem;">(SEN)</span>':''}</span>
      <span style="font-family:var(--font-mono); color:var(--amber);">${d.prestige} PJ</span>
    </div>`;
  }).join('');
}

/* =========================================================================
   ODA SEÇİMİ (Genel / Özel)
   ========================================================================= */
document.getElementById('card-random').addEventListener('click', ()=>{ sendMsg({type:'join_public'}); });
document.getElementById('card-private').addEventListener('click', ()=> openModal('modal-private'));
document.getElementById('tab-create').addEventListener('click', ()=> switchPrivateTab('create'));
document.getElementById('tab-join').addEventListener('click', ()=> switchPrivateTab('join'));
function switchPrivateTab(name){
  document.getElementById('tab-create').classList.toggle('active-tab', name==='create');
  document.getElementById('tab-join').classList.toggle('active-tab', name==='join');
  document.getElementById('pane-create').classList.toggle('active', name==='create');
  document.getElementById('pane-join').classList.toggle('active', name==='join');
}
document.getElementById('btn-generate-code').addEventListener('click', ()=>{
  closeModal('modal-private');
  sendMsg({ type:'create_private' });
});
document.getElementById('btn-join-code').addEventListener('click', ()=>{
  const val = document.getElementById('join-code-input').value.trim().toUpperCase();
  const errEl = document.getElementById('join-error');
  if(val.length !== 6){ errEl.textContent = 'Kod 6 karakter olmalı.'; return; }
  errEl.textContent = '';
  closeModal('modal-private');
  sendMsg({ type:'join_private', code: val });
});

/* =========================================================================
   OYUN SABİTLERİ (SUNUCU İLE AYNI OLMALI!)
   ========================================================================= */
const MATCH_SECONDS = 300;
const WEAPONS = [
  { key:'sniper', name:'Keskin Nişancı', icon:'🎯', fireRate:1150, bulletSpeed:1700, spread:0.012, melee:false },
  { key:'ak47',   name:'AK47',           icon:'🔫', fireRate:110,  bulletSpeed:980,  spread:0.075, melee:false },
  { key:'knife',  name:'Bıçak',          icon:'🔪', fireRate:480,  bulletSpeed:0,    spread:0,     melee:true }
];
const OBSTACLES = [
  {x:400,y:300,w:220,h:120},{x:900,y:600,w:160,h:260},{x:1500,y:250,w:300,h:140},
  {x:2100,y:500,w:180,h:180},{x:2600,y:300,w:220,h:220},{x:300,y:1100,w:260,h:160},
  {x:800,y:1400,w:180,h:180},{x:1400,y:1200,w:260,h:160},{x:1900,y:1500,w:200,h:220},
  {x:2500,y:1300,w:240,h:160},{x:1150,y:900,w:140,h:140},{x:2800,y:900,w:180,h:260},
  {x:150,y:1800,w:220,h:150},{x:2900,y:1900,w:200,h:180},{x:1650,y:1850,w:220,h:140}
];

/* =========================================================================
   OYUN DURUMU (İSTEMCİ TARAFI)
   ========================================================================= */
let G = null;
let rafId = null;
const isTouch = ('ontouchstart' in window) || navigator.maxTouchPoints > 0;

const canvas = document.getElementById('gameCanvas');
const ctx = canvas.getContext('2d');
function resizeCanvas(){ canvas.width = window.innerWidth; canvas.height = window.innerHeight; }
window.addEventListener('resize', resizeCanvas);
resizeCanvas();

function clamp(v,a,b){ return Math.max(a, Math.min(b, v)); }
function dist(a,b){ return Math.hypot(a.x-b.x, a.y-b.y); }
function rand(a,b){ return a + Math.random()*(b-a); }

function onRoomJoined(msg){
  G = {
    roomType: msg.roomType, code: msg.code, selfId: msg.selfId,
    worldW: msg.worldW, worldH: msg.worldH,
    entities: new Map(), bullets: [], killfeed: [],
    timeLeft: msg.timeLeft, camera:{x:0,y:0},
    input: { up:false,down:false,left:false,right:false, mouseX:0, mouseY:0, firing:false },
    mobile: { moveX:0, moveY:0, aimAngle:0, firing:false },
    lastStateSent: 0
  };
  for(const p of msg.players){
    G.entities.set(p.id, makeEntityFromServer(p));
  }
  document.getElementById('roomTypeLabel').textContent = msg.roomType === 'public' ? 'GENEL ODA' : ('ÖZEL ODA · '+msg.code);
  document.getElementById('timerBadge').firstChild.textContent = formatTime(G.timeLeft);
  updateHealthUI();
  updateWeaponUI();
  showScreen('screen-game');
  if(rafId) cancelAnimationFrame(rafId);
  G.lastTick = performance.now();
  loop();
}
function makeEntityFromServer(p){
  return {
    id:p.id, name:p.name, x:p.x, y:p.y, angle:p.angle||0, hp:p.hp!=null?p.hp:100, maxHp:100,
    weaponIndex: p.weaponIndex!=null? p.weaponIndex:1, kills:p.kills||0, deaths:p.deaths||0,
    alive: p.alive!==false, isSelf: p.id === G.selfId
  };
}
function myEntity(){ return G.entities.get(G.selfId); }

function onPlayerJoined(p){
  if(!G) return;
  if(!G.entities.has(p.id)) G.entities.set(p.id, makeEntityFromServer(p));
  pushKillfeed(`${p.name} odaya katıldı`);
}
function onPlayerLeft(id){
  if(!G) return;
  const e = G.entities.get(id);
  if(e) pushKillfeed(`${e.name} odadan ayrıldı`);
  G.entities.delete(id);
}
function onStateUpdate(msg){
  if(!G) return;
  const e = G.entities.get(msg.id);
  if(!e || e.isSelf) return;
  e.x = msg.x; e.y = msg.y; e.angle = msg.angle;
  if(typeof msg.weaponIndex === 'number') e.weaponIndex = msg.weaponIndex;
}
function onBulletVisual(msg){
  if(!G) return;
  const w = WEAPONS[msg.weaponIndex];
  if(!w || w.melee) return;
  G.bullets.push({
    x: msg.x, y: msg.y,
    vx: Math.cos(msg.angle)*w.bulletSpeed, vy: Math.sin(msg.angle)*w.bulletSpeed,
    life: 2.5
  });
}
function onHit(msg){
  if(!G) return;
  const target = G.entities.get(msg.targetId);
  if(target){ target.hp = msg.hp; if(target.isSelf) updateHealthUI(); }
}
function onKill(msg){
  if(!G) return;
  const killer = G.entities.get(msg.killerId);
  const target = G.entities.get(msg.targetId);
  if(killer) killer.kills += 1;
  if(target){ target.deaths += 1; target.alive = false; target.hp = 0; }
  pushKillfeed(`${msg.killerName} ⚔ ${msg.targetName} (${msg.weaponName})`);
  if(target && target.isSelf){
    const banner = document.getElementById('deathBanner');
    banner.style.display='block';
    setTimeout(()=>{ banner.style.display='none'; }, 1400);
  }
}
function onRespawn(msg){
  if(!G) return;
  const e = G.entities.get(msg.id);
  if(!e) return;
  e.x = msg.x; e.y = msg.y; e.hp = e.maxHp; e.alive = true;
  if(e.isSelf) updateHealthUI();
}
function onTimer(timeLeft){
  if(!G) return;
  G.timeLeft = timeLeft;
  document.getElementById('timerBadge').firstChild.textContent = formatTime(timeLeft);
}
function formatTime(s){ s=Math.max(0,s); const m=Math.floor(s/60), sec=s%60; return String(m).padStart(2,'0')+':'+String(sec).padStart(2,'0'); }

function onMatchEnd(msg){
  if(!G) return;
  cancelAnimationFrame(rafId);
  const listEl = document.getElementById('results-list');
  listEl.innerHTML = msg.ranking.map((r,i)=>{
    const me = r.id === G.selfId;
    return `<div class="result-row ${me?'me':''}"><span>#${i+1} ${escapeHtml(r.name)}</span><span>${r.kills} kill / ${r.deaths} ölüm</span></div>`;
  }).join('');
  const noteEl = document.getElementById('prestige-note');
  const myGain = msg.prestigeGains ? msg.prestigeGains[G.selfId] : undefined;
  if(msg.roomType === 'public'){
    if(myGain){
      currentPrestige = msg.newPrestige[G.selfId];
      noteEl.className = 'prestige-note awarded';
      noteEl.textContent = `🏆 Genel oda maçını tamamladın ve +${myGain} Prestij puanı kazandın!`;
    } else {
      noteEl.className = 'prestige-note none';
      noteEl.textContent = 'Prestij puanı yalnızca ilk 3\'e verilir. Bir dahaki sefere!';
    }
  } else {
    noteEl.className = 'prestige-note none';
    noteEl.textContent = '🔒 Özel oda olduğu için prestij puanı kazanılmadı.';
  }
  showScreen('screen-results');
}
document.getElementById('btn-back-menu').addEventListener('click', ()=>{
  document.getElementById('menu-prestige').textContent = currentPrestige;
  sendMsg({type:'leave_room'});
  G = null;
  enterMenu();
});

/* =========================================================================
   INPUT — PC
   ========================================================================= */
window.addEventListener('keydown', e=>{
  if(!G) return;
  if(!document.getElementById('screen-game').classList.contains('active')) return;
  const k = e.key.toLowerCase();
  if(k==='w'||e.key==='ArrowUp') G.input.up = true;
  if(k==='s'||e.key==='ArrowDown') G.input.down = true;
  if(k==='a'||e.key==='ArrowLeft') G.input.left = true;
  if(k==='d'||e.key==='ArrowRight') G.input.right = true;
  if(k==='1') setWeapon(0);
  if(k==='2') setWeapon(1);
  if(k==='3') setWeapon(2);
  if(e.key === 'Tab'){ e.preventDefault(); document.getElementById('tabScoreboard').classList.add('show'); }
});
window.addEventListener('keyup', e=>{
  if(!G) return;
  const k = e.key.toLowerCase();
  if(k==='w'||e.key==='ArrowUp') G.input.up = false;
  if(k==='s'||e.key==='ArrowDown') G.input.down = false;
  if(k==='a'||e.key==='ArrowLeft') G.input.left = false;
  if(k==='d'||e.key==='ArrowRight') G.input.right = false;
  if(e.key === 'Tab'){ document.getElementById('tabScoreboard').classList.remove('show'); }
});
canvas.addEventListener('mousemove', e=>{
  if(!G) return;
  const r = canvas.getBoundingClientRect();
  G.input.mouseX = e.clientX - r.left;
  G.input.mouseY = e.clientY - r.top;
});
canvas.addEventListener('mousedown', e=>{ if(e.button===0 && G) G.input.firing = true; });
window.addEventListener('mouseup', e=>{ if(e.button===0 && G) G.input.firing = false; });

document.querySelectorAll('.weapon-slot[data-w]').forEach(el=>{
  el.addEventListener('click', ()=> setWeapon(parseInt(el.dataset.w,10)));
});
function setWeapon(idx){
  const me = myEntity();
  if(!G || !me || !me.alive) return;
  me.weaponIndex = idx;
  updateWeaponUI();
}
function updateWeaponUI(){
  const me = myEntity();
  if(!me) return;
  document.querySelectorAll('.weapon-slot[data-w]').forEach(el=>{
    el.classList.toggle('active', parseInt(el.dataset.w,10) === me.weaponIndex);
  });
  document.querySelectorAll('.weapon-slot[data-mw]').forEach(el=>{
    el.classList.toggle('active', parseInt(el.dataset.mw,10) === me.weaponIndex);
  });
}

/* =========================================================================
   INPUT — MOBİL (çift joystick + ateş butonu)
   ========================================================================= */
const activeTouches = {};
function setupJoystick(zoneEl, knobEl, zoneName){
  zoneEl.addEventListener('touchstart', e=>{
    for(const t of e.changedTouches){
      const r = zoneEl.getBoundingClientRect();
      const cx = r.left + r.width/2, cy = r.top + r.height/2;
      activeTouches[t.identifier] = { zone: zoneName, cx, cy, radius:r.width/2 };
    }
    e.preventDefault();
  }, {passive:false});
  zoneEl.addEventListener('touchmove', e=>{
    for(const t of e.changedTouches){
      const info = activeTouches[t.identifier];
      if(!info || info.zone !== zoneName) continue;
      handleJoyMove(zoneName, t, info, knobEl);
    }
    e.preventDefault();
  }, {passive:false});
  function endTouch(e){
    for(const t of e.changedTouches){
      const info = activeTouches[t.identifier];
      if(info && info.zone === zoneName){
        delete activeTouches[t.identifier];
        knobEl.style.transform = 'translate(-50%,-50%)';
        if(zoneName === 'left' && G){ G.mobile.moveX=0; G.mobile.moveY=0; }
      }
    }
  }
  zoneEl.addEventListener('touchend', endTouch);
  zoneEl.addEventListener('touchcancel', endTouch);
}
function handleJoyMove(zoneName, touch, info, knobEl){
  let dx = touch.clientX - info.cx;
  let dy = touch.clientY - info.cy;
  const mag = Math.hypot(dx,dy);
  const maxR = info.radius;
  if(mag > maxR){ dx = dx/mag*maxR; dy = dy/mag*maxR; }
  knobEl.style.transform = `translate(calc(-50% + ${dx}px), calc(-50% + ${dy}px))`;
  const nx = dx/maxR, ny = dy/maxR;
  if(!G) return;
  if(zoneName === 'left'){ G.mobile.moveX = nx; G.mobile.moveY = ny; }
  else if(mag > 8){ G.mobile.aimAngle = Math.atan2(dy,dx); }
}
setupJoystick(document.getElementById('joyLeft'), document.getElementById('joyLeftKnob'), 'left');
setupJoystick(document.getElementById('joyRight'), document.getElementById('joyRightKnob'), 'right');

const fireBtn = document.getElementById('fireBtn');
fireBtn.addEventListener('touchstart', e=>{ e.preventDefault(); fireBtn.classList.add('pressed'); if(G) G.mobile.firing = true; }, {passive:false});
fireBtn.addEventListener('touchend', e=>{ e.preventDefault(); fireBtn.classList.remove('pressed'); if(G) G.mobile.firing = false; }, {passive:false});
document.querySelectorAll('.weapon-slot[data-mw]').forEach(el=>{
  el.addEventListener('touchstart', e=>{ e.preventDefault(); setWeapon(parseInt(el.dataset.mw,10)); }, {passive:false});
});

/* =========================================================================
   ANA DÖNGÜ
   ========================================================================= */
function loop(){
  const now = performance.now();
  let dt = (now - G.lastTick)/1000;
  if(dt > 0.1) dt = 0.1;
  G.lastTick = now;
  update(dt);
  render();
  rafId = requestAnimationFrame(loop);
}

function update(dt){
  updateSelf(dt);
  updateBullets(dt);
  updateCamera();
  renderScoreboards();

  G.lastStateSent = (G.lastStateSent||0) + dt;
  if(G.lastStateSent >= 0.05){
    G.lastStateSent = 0;
    const me = myEntity();
    if(me){
      sendMsg({ type:'state', x: me.x, y: me.y, angle: me.angle, weaponIndex: me.weaponIndex });
    }
  }
}

function updateSelf(dt){
  const me = myEntity();
  if(!me || !me.alive) return;
  let mx=0, my=0;
  if(isTouch){ mx = G.mobile.moveX; my = G.mobile.moveY; }
  else{
    if(G.input.up) my -= 1;
    if(G.input.down) my += 1;
    if(G.input.left) mx -= 1;
    if(G.input.right) mx += 1;
    const mag = Math.hypot(mx,my);
    if(mag>0){ mx/=mag; my/=mag; }
  }
  const speed = 320;
  moveEntity(me, mx*speed*dt, my*speed*dt);

  if(isTouch){ me.angle = G.mobile.aimAngle; }
  else{
    const screenX = me.x - G.camera.x;
    const screenY = me.y - G.camera.y;
    me.angle = Math.atan2(G.input.mouseY - screenY, G.input.mouseX - screenX);
  }

  me.fireTimer = (me.fireTimer||0) - dt*1000;
  const firing = isTouch ? G.mobile.firing : G.input.firing;
  const w = WEAPONS[me.weaponIndex];
  if(firing && me.fireTimer <= 0){
    me.fireTimer = w.fireRate;
    if(w.melee){
      sendMsg({ type:'melee' });
      // yerel görsel: kısa bir vuruş efekti (hasar sunucudan gelecek)
    } else {
      const spread = (Math.random()-0.5)*2*w.spread;
      const ang = me.angle + spread;
      const ox = me.x + Math.cos(me.angle)*22, oy = me.y + Math.sin(me.angle)*22;
      sendMsg({ type:'shoot', x: ox, y: oy, angle: ang, weaponIndex: me.weaponIndex });
      // yerel görsel tracer (anında geri bildirim için); sunucu da 'bullet' yayınlayıp diğerlerine gösterecek
      G.bullets.push({ x: ox, y: oy, vx: Math.cos(ang)*w.bulletSpeed, vy: Math.sin(ang)*w.bulletSpeed, life:2.5 });
    }
  }
}

function moveEntity(e, dx, dy){
  let nx = clamp(e.x+dx, 20, G.worldW-20);
  let ny = clamp(e.y+dy, 20, G.worldH-20);
  for(const o of OBSTACLES){
    if(circleRectOverlap(nx,ny,18,o)){
      if(!circleRectOverlap(e.x,ny,18,o)) ny = e.y;
      else if(!circleRectOverlap(nx,e.y,18,o)) nx = e.x;
      else { nx = e.x; ny = e.y; }
    }
  }
  e.x = nx; e.y = ny;
}
function circleRectOverlap(cx,cy,r,rect){
  const closestX = clamp(cx, rect.x, rect.x+rect.w);
  const closestY = clamp(cy, rect.y, rect.y+rect.h);
  const dx = cx-closestX, dy = cy-closestY;
  return (dx*dx+dy*dy) < r*r;
}

function updateBullets(dt){
  for(let i=G.bullets.length-1;i>=0;i--){
    const b = G.bullets[i];
    b.x += b.vx*dt; b.y += b.vy*dt; b.life -= dt;
    let dead = b.life<=0 || b.x<0||b.x>G.worldW||b.y<0||b.y>G.worldH;
    if(!dead){ for(const o of OBSTACLES){ if(circleRectOverlap(b.x,b.y,4,o)){ dead=true; break; } } }
    if(dead) G.bullets.splice(i,1);
  }
}

function updateCamera(){
  const me = myEntity();
  if(!me) return;
  G.camera.x = clamp(me.x - canvas.width/2, 0, Math.max(0,G.worldW-canvas.width));
  G.camera.y = clamp(me.y - canvas.height/2, 0, Math.max(0,G.worldH-canvas.height));
}

function pushKillfeed(text){
  const el = document.getElementById('killfeed');
  const div = document.createElement('div');
  div.className='killfeed-item';
  div.textContent = text;
  el.appendChild(div);
  setTimeout(()=>{ div.remove(); }, 3500);
  while(el.children.length > 6) el.removeChild(el.firstChild);
}
function updateHealthUI(){
  const me = myEntity();
  if(!me) return;
  const pct = clamp((me.hp/me.maxHp)*100,0,100);
  document.getElementById('healthBarFill').style.width = pct+'%';
}

/* ---------------- RENDER ---------------- */
function render(){
  ctx.fillStyle = '#12181c';
  ctx.fillRect(0,0,canvas.width,canvas.height);
  ctx.save();
  ctx.translate(-G.camera.x, -G.camera.y);

  ctx.strokeStyle = 'rgba(255,255,255,0.04)'; ctx.lineWidth = 1;
  const gs = 80;
  for(let x=0;x<=G.worldW;x+=gs){ ctx.beginPath(); ctx.moveTo(x,0); ctx.lineTo(x,G.worldH); ctx.stroke(); }
  for(let y=0;y<=G.worldH;y+=gs){ ctx.beginPath(); ctx.moveTo(0,y); ctx.lineTo(G.worldW,y); ctx.stroke(); }

  ctx.strokeStyle = 'rgba(76,201,240,0.4)'; ctx.lineWidth = 4;
  ctx.strokeRect(0,0,G.worldW,G.worldH);

  for(const o of OBSTACLES){
    ctx.fillStyle = '#232b31'; ctx.strokeStyle = 'rgba(76,201,240,0.25)'; ctx.lineWidth=2;
    ctx.fillRect(o.x,o.y,o.w,o.h); ctx.strokeRect(o.x,o.y,o.w,o.h);
  }

  ctx.fillStyle = '#ffd166';
  for(const b of G.bullets){ ctx.beginPath(); ctx.arc(b.x,b.y,4,0,Math.PI*2); ctx.fill(); }

  for(const e of G.entities.values()){ if(e.alive) drawEntity(e); }

  ctx.restore();
}
function drawEntity(e){
  const isMe = e.isSelf;
  ctx.save();
  ctx.translate(e.x, e.y);
  ctx.rotate(e.angle);
  ctx.fillStyle = isMe ? '#4cc9f0' : '#e63946';
  ctx.beginPath(); ctx.moveTo(24,0); ctx.lineTo(-14,10); ctx.lineTo(-14,-10); ctx.closePath(); ctx.fill();
  ctx.restore();

  ctx.beginPath();
  ctx.fillStyle = isMe ? 'rgba(76,201,240,0.85)' : 'rgba(230,57,70,0.85)';
  ctx.arc(e.x,e.y,18,0,Math.PI*2); ctx.fill();
  ctx.lineWidth=2; ctx.strokeStyle= isMe? '#bfefff':'#ffc2c6'; ctx.stroke();

  ctx.fillStyle = 'rgba(0,0,0,0.55)'; ctx.fillRect(e.x-30, e.y-42, 60, 8);
  ctx.fillStyle = isMe ? '#4cc9f0' : '#3ddc97';
  ctx.fillRect(e.x-30, e.y-42, 60*(e.hp/e.maxHp), 8);

  ctx.font = '12px Rajdhani, sans-serif'; ctx.fillStyle = '#d9e4e8'; ctx.textAlign = 'center';
  ctx.fillText(e.name, e.x, e.y-48);
}

function renderScoreboards(){
  const sorted = Array.from(G.entities.values()).sort((a,b)=> b.kills-a.kills || a.deaths-b.deaths);
  const rowsHtml = sorted.map(e=>{
    return `<div class="sb-row ${e.isSelf?'me':''}"><span class="sb-name">${escapeHtml(e.name)}</span><span>${e.kills}/${e.deaths}</span></div>`;
  }).join('');
  document.getElementById('scoreboardRows').innerHTML = rowsHtml;
  document.getElementById('tabScoreboardRows').innerHTML = rowsHtml;
}
</script>
</body>
</html>
